  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::IntroDialogue
  dialoguePanel: {fileID: 343192684}
  nameText: {fileID: 1873647301}
  dialogueText: {fileID: 749120335}
  dialogues:
  - speaker: Prof. Arya
    text: Ahh, Tidak Apa-apa
  - speaker: Prof. Arya
    text: Aku Cuma tertidur Cukup Lama, Di tempat sini
  - speaker: Prof. Arya
    text: Ngomong-ngomong, Selamat.. Kau Menemukan ku Disini
  - speaker: Prof. Arya
    text: Ini Adalah Inti Dari Dunia Lontar, Tidak ada Siapa pun yang bisa sampai
      sini.
  - speaker: Prof. Arya
    text: Yahh Begitulah, Sampai Saya-
  - speaker: Saka
    text: Tunggu..
  - speaker: Saka
    text: Bagaimana Ayah bisa tau, kalau aku ikut Masuk ke Dunia ini?
  - speaker: Prof. Arya
    text: Saya Melihatmu Saka, Saya terus Memantau mu..
