MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 381522425}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 5ee3062132dfaaf4cb11490cda12613f, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::IntroDialogue
  dialoguePanel: {fileID: 343192684}
  nameText: {fileID: 1873647301}
  dialogueText: {fileID: 749120335}
  dialogues:
  - speaker: Prof. Arya
    text: Pergilah..
  - speaker: Prof. Arya
    text: Lupakan Ayah, Ayah Baik baik saja..
  - speaker: Prof. Arya
    text: Bukankah dulu kau pernah berkata...
  - speaker: Prof. Arya
    text: Kau ingin menjadi arkeolog hebat...
  - speaker: Prof. Arya
    text: Menjelajahi seluruh Nusantara.
  - speaker: Prof. Arya
    text: Meneruskan Jejak yang bahkan belum sempat Ayah selesaikan.
  - speaker: Saka
    text: Itu... tidak ada hubungannya!...
  - speaker: Saka
    text: Aku hanya ingin membawa Ayah pulang...
  - speaker: Prof. Arya
    text: Sudahlah, Nak...
  - speaker: Prof. Arya
    text: Kadang... kita harus mengorbankan sesuatu..
  - speaker: Prof. Arya
    text: Demi menyelamatkan lebih banyak orang.
  - speaker: Prof. Arya
    text: Sini..
  - speaker: Prof. Arya
    text: Portal itu tidak akan bertahan lama.
  typingSpeed: 0.03
  freezePlayer: 1
  unfreezePlayerWhenFinished: 1
  flashbackPlayer: {fileID: 52204344}
