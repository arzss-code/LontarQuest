  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 5ee3062132dfaaf4cb11490cda12613f, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::IntroDialogue
  dialoguePanel: {fileID: 22974883}
  nameText: {fileID: 695655824}
  dialogueText: {fileID: 1791212345}
  dialogues:
  - speaker: Saka
    text: Ugh... kepalaku... Apa yang baru saja terjadi?
  - speaker: Saka
    text: Ruang bawah tanah tadi... obor itu... semuanya tiba-tiba tersedot ke dalam
      portal.
  - speaker: Saka
    text: Dan... tempat apa ini? Dinding batu ini dipenuhi dengan relief Aksara Kawi
      kuno, tapi... kenapa semuanya bercahaya?
  - speaker: Saka
    text: Gravitasinya terasa aneh... dan udaranya sangat berat. Mungkinkah ini 'Dimensi
      Lontar' yang dicari Ayah?
  - speaker: Saka
    text: Kalau ini satu-satunya jalan untuk menemukan Ayah, aku harus bersiap menghadapi
      apa pun di depan sana.
  typingSpeed: 0.03
  freezePlayer: 1
